# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_MANAGER_CHAT_ID=your-manager-chat-id

# MongoDB (same cluster as the backend)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/parties247

# Backend service URL (where scrape-party / approve / reject calls go)
BACKEND_URL=https://your-backend.onrender.com

# Shared secret — must match SERVICE_TOKEN in the backend
SERVICE_TOKEN=change-me-to-a-long-random-string

# Go-Out account credentials
GOOUT_ACCOUNT1_EMAIL=account1@example.com
GOOUT_ACCOUNT1_PASSWORD=password1
GOOUT_ACCOUNT1_REFERRAL=ref1

GOOUT_ACCOUNT2_EMAIL=account2@example.com
GOOUT_ACCOUNT2_PASSWORD=password2
GOOUT_ACCOUNT2_REFERRAL=ref2

# Scheduling (UTC hour for daily scrape, default 6)
GOOUT_SCRAPE_HOUR=6

# Flask API port inside the container
API_PORT=5001
