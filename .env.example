# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_MANAGER_CHAT_ID=your-manager-chat-id

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_DB_NAME=parties247

# Backend service URL
BACKEND_URL=https://your-backend.onrender.com

# Admin password for the backend (used to get a JWT for approve/reject calls)
ADMIN_PASSWORD=your-admin-password

# Shared secret for scrape-party internal endpoint
SERVICE_TOKEN=change-me-to-a-long-random-string

# Go-Out account credentials
GOOUT_ACCOUNT1_EMAIL=account1@example.com
GOOUT_ACCOUNT1_PASSWORD=password1
GOOUT_ACCOUNT1_REFERRAL=ref1

GOOUT_ACCOUNT2_EMAIL=account2@example.com
GOOUT_ACCOUNT2_PASSWORD=password2
GOOUT_ACCOUNT2_REFERRAL=ref2

# UTC hour for daily automatic scrape (default 8)
GOOUT_SCRAPE_HOUR=8
